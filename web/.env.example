NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=sk_...
# Groq Whisper — used for non-zh/ja ASR (see lib/asr). Required for those langs.
GROQ_API_KEY=gsk_...

# Cost guardrail (lib/quota.ts). Max clips a non-owner account may hold before
# /api/upload returns 429. Default 20 if unset.
CLIP_LIMIT_PER_USER=20
# Max length of a single clip (minutes) for non-owners. Enforced in stage 1
# before any paid work — over-limit clips fail with a "please trim" message.
# Pairs with the count cap to bound worst-case cost. Default 60 if unset.
MAX_CLIP_MINUTES=60
# Accounts exempt from the clip cap AND allowed to use YouTube import — the
# owner(s). Comma-separated Supabase user ids. NEXT_PUBLIC_OWNER_IDS is the
# clip-cap exemption; if unset it falls back to the YouTube allowlist below.
NEXT_PUBLIC_OWNER_IDS=
NEXT_PUBLIC_YOUTUBE_IMPORT_ALLOWLIST=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=shadowing-media
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# Shared secret for Vercel Cron → /api/cron/reap-jobs + /api/cron/review.
# Generate any random string; set the same value in the Vercel project env.
CRON_SECRET=

# Review bot (Telegram). Token from @BotFather; the webhook secret is any random
# string you pass to setWebhook (Telegram echoes it back for verification).
# BOT_USERNAME (no @) powers the "Connect Telegram" button's t.me deep link.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=

# App's own base URL, used for deep links in review messages (e.g. the "Shadow
# in app" button). On Vercel, VERCEL_URL is used automatically if this is unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000
